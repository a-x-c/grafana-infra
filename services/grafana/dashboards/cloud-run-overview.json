{
  "uid": "{{project_slug}}-cloud-run-overview",
  "title": "{{display_name}} — Cloud Run Overview",
  "tags": ["{{project_slug}}", "cloud-run"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": "service-one|service-two|service-three",
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "options": [
          {"selected": true, "text": "All", "value": "$__all"},
          {"selected": false, "text": "service-one", "value": "service-one"},
          {"selected": false, "text": "service-two", "value": "service-two"},
          {"selected": false, "text": "service-three", "value": "service-three"}
        ],
        "query": "service-one,service-two,service-three"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "stackdriver", "uid": "{{project_slug}}-gcp-monitoring"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "{{gcp_project}}",
            "metricType": "run.googleapis.com/request_count",
            "filters": ["resource.label.service_name", "=~", "$service"],
            "aliasBy": "{{resource.label.service_name}}",
            "alignmentPeriod": "stackdriver-auto",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM",
            "groupBys": ["resource.label.service_name"]
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request latency p95 (ms)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "stackdriver", "uid": "{{project_slug}}-gcp-monitoring"},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "{{gcp_project}}",
            "metricType": "run.googleapis.com/request_latencies",
            "filters": ["resource.label.service_name", "=~", "$service"],
            "aliasBy": "{{resource.label.service_name}}",
            "alignmentPeriod": "stackdriver-auto",
            "perSeriesAligner": "ALIGN_DELTA",
            "crossSeriesReducer": "REDUCE_PERCENTILE_95",
            "groupBys": ["resource.label.service_name"]
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Instance count",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "stackdriver", "uid": "{{project_slug}}-gcp-monitoring"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "{{gcp_project}}",
            "metricType": "run.googleapis.com/container/instance_count",
            "filters": ["resource.label.service_name", "=~", "$service"],
            "aliasBy": "{{resource.label.service_name}}",
            "alignmentPeriod": "stackdriver-auto",
            "perSeriesAligner": "ALIGN_MEAN",
            "crossSeriesReducer": "REDUCE_SUM",
            "groupBys": ["resource.label.service_name"]
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Recent logs (WARNING+)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "googlecloud-logging-datasource", "uid": "{{project_slug}}-gcp-logging"},
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "projectId": "{{gcp_project}}",
          "queryText": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=~\"$service\" AND severity>=WARNING"
        }
      ]
    }
  ]
}
